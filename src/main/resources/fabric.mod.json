{
	"schemaVersion": 1,
	"id": "transllmate",
	"version": "${version}",
	"name": "TransLLMate",
	"description": "Translate messages using self-hosted LLM",
	"authors": ["black car"],
	"contact": {"homepage": "https://github.com/Bl4ckCarpetPng/TransLLMate"},
	"license": "GPLv3",
	"icon": "assets/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": ["blackcar.transllmate.TransLLMate"],
		"client": ["blackcar.transllmate.TransLLMateClient"],
		"modmenu": ["blackcar.transllmate.config.ModMenuIntegration"]
	},
	"mixins": [
		"transllmate.mixins.json",
		{
			"config": "transllmate.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": ">=26.1",
		"java": ">=25",
		"fabric-api": "*",
		"yet_another_config_lib_v3": "*"
	},
	"recommends": {
		"modmenu": "*"
	}
}
